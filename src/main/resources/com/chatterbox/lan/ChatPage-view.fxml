<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="506.0" prefWidth="605.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.chatterbox.lan.controllers.ChatPageController">

    <BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" stylesheets="@style.css" visible="true" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
        <left>

            <VBox prefHeight="400.0" prefWidth="200.0" BorderPane.alignment="CENTER" VBox.vgrow="ALWAYS">
                <HBox style="-fx-padding: 10;">
                    <children>
                        <Label style="-fx-font-size: 14; -fx-font-weight: bold;" text="Conversations" />
                    </children>
                </HBox>
                <ListView fx:id="conversationList" prefHeight="400.0" prefWidth="200.0" VBox.vgrow="ALWAYS" />

            <HBox alignment="BOTTOM_LEFT" spacing="10">
               <children>
                  <Button onAction="#onOpenAddFriend" mnemonicParsing="false" prefHeight="26.0" prefWidth="102.0" text="ADD" />
                  <Button onAction="#onOpenCreateConversation" mnemonicParsing="false" prefHeight="26.0" prefWidth="115.0" text="CREATE" />
               </children>
            </HBox>
            </VBox>
        </left>
        <center>
            <VBox>
                <HBox prefHeight="60.0" prefWidth="200.0" style="-fx-background-color: #b5c9e8; -fx-padding: 10;">
                    <children>
                        <Label fx:id="inboxLabel" style="-fx-font-size: 16; -fx-font-weight: bold;" text="Select a conversation" />
                    </children>
                </HBox>
                <ListView fx:id="messageList" styleClass="message-list" VBox.vgrow="ALWAYS" />
                <HBox spacing="10" style="-fx-padding: 10; -fx-background-color: #f0f0f0;">
                    <children>
                        <TextField fx:id="inputMessage" promptText="Type a message..." HBox.hgrow="ALWAYS" />
                        <Button fx:id="sendButton" onAction="#onSendMessage" text="Send" />
                    </children>
                </HBox>
            </VBox>
        </center>
    </BorderPane>
    <VBox fx:id="createConversationOverlay" alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="374.0" prefWidth="448.0" spacing="10" style="-fx-border-color: gray; -fx-background-color: white; -fx-padding: 16; -fx-background-radius: 10;" visible="false">
         <HBox alignment="CENTER_LEFT" spacing="10">
             <Label style="-fx-font-size: 16; -fx-font-weight: bold;" text="Create Conversation" />
             <Pane HBox.hgrow="ALWAYS" />
             <Button onAction="#onCloseCreateConversation" text="X" />
         </HBox>

         <Label text="Conversation Name" />
         <TextField fx:id="conversationNameField" promptText="e.g. Project" />

         <Label text="Select Members" />
         <ListView fx:id="availableUsersList" prefHeight="180" />

         <HBox alignment="CENTER_RIGHT" spacing="10">
             <Button onAction="#onCloseCreateConversation" text="Cancel" />
             <Button onAction="#onSubmitCreateConversation" text="Create" />
         </HBox>
    </VBox>

    <VBox fx:id="addFriendOverlay" alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="275.0" prefWidth="448.0" spacing="10" style="-fx-border-color: gray; -fx-background-color: white; -fx-padding: 16; -fx-background-radius: 10;" visible="false">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label style="-fx-font-size: 16; -fx-font-weight: bold;" text="Add Friend" />
            <Pane HBox.hgrow="ALWAYS" />
            <Button onAction="#onCloseAddFriend" text="X" />
        </HBox>

        <Label text="Friend Username" />
        <TextField fx:id="friendUserNameField" promptText="e.g. Project" />

        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Button onAction="#onCloseAddFriend" text="Cancel" />
            <Button onAction="#onSubmitAddFriend" text="Create" />
        </HBox>
    </VBox>
</StackPane>
