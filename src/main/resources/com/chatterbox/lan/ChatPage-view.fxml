<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.chatterbox.lan.controllers.ChatPageController">
   <left>
      <VBox prefHeight="400.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <HBox style="-fx-padding: 10;">
            <children>
               <Label text="Conversations" style="-fx-font-size: 14; -fx-font-weight: bold;" />
            </children>
         </HBox>
         <ListView fx:id="conversationList" prefHeight="400.0" prefWidth="200.0" VBox.vgrow="ALWAYS" />
      </VBox>
   </left>
   <center>
      <VBox>
         <HBox prefHeight="60.0" prefWidth="200.0" style="-fx-background-color: #b5c9e8; -fx-padding: 10;">
            <children>
               <Label fx:id="inboxLabel" text="Select a conversation" style="-fx-font-size: 16; -fx-font-weight: bold;" />
            </children>
         </HBox>
         <ListView fx:id="messageList" styleClass="message-list" VBox.vgrow="ALWAYS" />
         <HBox spacing="10" style="-fx-padding: 10; -fx-background-color: #f0f0f0;">
            <children>
               <TextField fx:id="inputMessage" promptText="Type a message..." HBox.hgrow="ALWAYS" />
               <Button fx:id="sendButton" text="Send" onAction="#onSendMessage" />
            </children>
         </HBox>
      </VBox>
   </center>
</BorderPane>