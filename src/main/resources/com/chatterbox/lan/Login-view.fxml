<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox alignment="CENTER" spacing="20" prefWidth="400" prefHeight="350" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.chatterbox.lan.controllers.LoginController">
    <padding>
        <Insets top="50" right="50" bottom="50" left="50"/>
    </padding>

    <Label text="Chatterbox Login" style="-fx-font-size: 24; -fx-font-weight: bold;"/>

    <VBox spacing="10" maxWidth="300">
        <Label text="Username:"/>
        <TextField fx:id="usernameField" promptText="Enter your username"/>

        <Label text="Quick select:"/>
        <ComboBox fx:id="userComboBox" promptText="Choose a user..." maxWidth="Infinity">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="jon"/>
                    <String fx:value="alice"/>
                    <String fx:value="bob"/>
                </FXCollections>
            </items>
        </ComboBox>

        <Button text="Login" onAction="#onLogin" maxWidth="Infinity" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14; -fx-padding: 10;"/>

        <Label fx:id="errorLabel" textFill="red" visible="false"/>
    </VBox>
</VBox>
